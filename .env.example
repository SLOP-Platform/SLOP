# SLOP v4 — Environment variables
# Copy to .env and fill in your values before running docker compose up.
# This file is mounted into the container at /srv/slop/.env
# and also read by docker compose when launching managed app containers.

# ── Required ──────────────────────────────────────────────────────────────
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com

# DNS provider API credentials (used by Traefik for DNS-01 TLS challenge)
# Cloudflare example — see https://dash.cloudflare.com/profile/api-tokens
CF_DNS_API_TOKEN=your_cloudflare_api_token

# ── Auto-generated by Platform Setup wizard ────────────────────────────────
# (change only if migrating an existing install)
POSTGRES_PASSWORD=changeme

# ── Optional ──────────────────────────────────────────────────────────────
# Paths (defaults match docker-compose.option-b.yml volume mounts)
CONFIG_ROOT=/srv/slop/config
MEDIA_ROOT=/mnt/media
PUID=1000
PGID=1000
TZ=America/Los_Angeles

# Cert authority: letsencrypt | zerossl | buypass | staging
CERT_RESOLVER=letsencrypt

# Notifications (install ntfy from catalog, then enable)
# NTFY_URL=http://ntfy:80
# NTFY_TOPIC=slop
